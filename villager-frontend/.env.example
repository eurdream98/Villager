# Windows: HOST=127.0.0.1 사용 시 다른 포트로 넘어갈 때 EFAULT 발생 가능 → localhost 권장
HOST=localhost
PORT=3000

# Supabase 대시보드 → Project Settings → API
# Project URL (https://xxxx.supabase.co 만, /auth/v1/callback 아님)
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# anon public key (긴 JWT 문자열)
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Authentication → URL Configuration → Redirect URLs:
#   http://127.0.0.1:3000
#   http://localhost:3000
#   https://villager-mauve.vercel.app/
# Site URL (배포): https://villager-mauve.vercel.app
# Redirect URLs에 로컬 포트도 추가: http://localhost:3001/  http://localhost:3000/
#
# ⚠️ 로컬 .env 에는 넣지 마세요 (있으면 Vercel로만 돌아감)
# REACT_APP_AUTH_REDIRECT_URL 은 Vercel Environment Variables 에만 설정
# Kakao Developers → 카카오 로그인 → Redirect URI:
#   https://<project-ref>.supabase.co/auth/v1/callback

# Spring 백엔드 (로컬: villager-backend/run-local.ps1)
# 직접 호출 (CORS 필요):
REACT_APP_API_URL=http://localhost:8080
# 또는 비우면 npm start 시 setupProxy가 /api → 8080 으로 전달
# REACT_APP_API_URL=

# 실시간 채팅 (Socket.IO) — 백엔드 API 사용 시 불필요
# REACT_APP_CHAT_WS_URL=http://127.0.0.1:3001
