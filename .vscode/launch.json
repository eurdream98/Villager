{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Villager Backend (local)",
      "request": "launch",
      "mainClass": "app.villager.VillagerBackendApplication",
      "projectName": "villager-backend",
      "cwd": "${workspaceFolder}/villager-backend",
      "vmArgs": "-Dspring.profiles.active=local -Dserver.port=8080 -Dserver.address=0.0.0.0 -Djava.net.useSystemProxies=false -DsocksProxyHost= -DsocksProxyPort= -Dhttp.proxyHost= -Dhttps.proxyHost= -Dhttp.nonProxyHosts=*",
      "env": {
        "HTTP_PROXY": "",
        "HTTPS_PROXY": "",
        "ALL_PROXY": "",
        "http_proxy": "",
        "https_proxy": "",
        "NO_PROXY": "*"
      }
    }
  ]
}
